  <tag k="network:transport:type" v="bus;trolleybus"/>
  <tag k="note" v="本关系包含上海市域内所有的公交车和无轨电车，不分所属公司和具体县区级网络，并按照编号、首字母拼音顺序排序，同音按照笔划排序，包括长三角一体化发展示范区对应所有线路，后附沪太快线，后附加驶入上海市境内的其他地市线路，不含有轨电车"/>
  <tag k="type" v="network"/>
 </relation>
